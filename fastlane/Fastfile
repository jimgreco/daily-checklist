ENV["FASTLANE_SKIP_UPDATE_CHECK"] = "1"

require "base64"
require "deliver/upload_metadata"

default_platform(:ios)
opt_out_usage

class ::Deliver::UploadMetadata
  unless method_defined?(:ritual_cue_review_attachment_file)
    alias_method :ritual_cue_review_attachment_file, :review_attachment_file

    def review_attachment_file(version)
      ritual_cue_review_attachment_file(version)
    rescue RuntimeError => error
      raise unless error.message == "No data" && options[:app_review_attachment_file].nil?

      UI.message("No App Store review detail exists yet; skipping review attachment cleanup")
    end
  end
end

APP_IDENTIFIER = "com.jimgreco.dailychecklist"
APP_TARGET = "Daily"
PROJECT_PATH = "Daily.xcodeproj"
SCREENSHOT_SCHEME = "DailyScreenshots"
SCREENSHOT_OUTPUT = "fastlane/screenshots"
METADATA_PATH = "fastlane/metadata"

def screenshot_devices
  raw_devices = ENV["SCREENSHOT_DEVICES"] || "iPhone 17 Pro Max"
  raw_devices.split(",").map(&:strip).reject(&:empty?)
end

platform :ios do
  desc "Capture App Store screenshots from deterministic local sample data"
  lane :screenshots do
    capture_ios_screenshots(
      project: PROJECT_PATH,
      scheme: SCREENSHOT_SCHEME,
      app_identifier: APP_IDENTIFIER,
      configuration: "Debug",
      devices: screenshot_devices,
      languages: ["en-US"],
      output_directory: SCREENSHOT_OUTPUT,
      clear_previous_screenshots: true,
      reinstall_app: true,
      clean: true,
      override_status_bar: true,
      skip_open_summary: true
    )
  end

  desc "Upload source-controlled App Store listing metadata to the editable version"
  lane :upload_metadata do
    upload_to_app_store(
      api_key: app_store_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: app_store_version,
      metadata_path: METADATA_PATH,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false
    )
  end

  desc "Upload generated screenshots to the editable App Store version"
  lane :upload_screenshots do
    upload_to_app_store(
      api_key: app_store_api_key,
      app_identifier: APP_IDENTIFIER,
      app_version: app_store_version,
      screenshots_path: SCREENSHOT_OUTPUT,
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false
    )
  end

  desc "Capture screenshots, then upload them to App Store Connect"
  lane :screenshots_and_upload do
    screenshots
    upload_screenshots
  end

  desc "Upload App Store metadata and screenshots"
  lane :upload_release_assets do
    upload_metadata
    upload_screenshots
  end

  private_lane :app_store_version do
    version_override = ENV["APP_STORE_VERSION"].to_s.strip
    if version_override.empty?
      get_version_number(
        xcodeproj: PROJECT_PATH,
        target: APP_TARGET
      )
    else
      version_override
    end
  end

  private_lane :app_store_api_key do
    api_key_content = ENV.fetch("APP_STORE_CONNECT_API_KEY").to_s.strip
    UI.user_error!("Missing required secret: APP_STORE_CONNECT_API_KEY") if api_key_content.empty?

    if api_key_content.include?("\\n") && !api_key_content.include?("\n")
      api_key_content = api_key_content.gsub("\\n", "\n")
    end

    unless api_key_content.include?("BEGIN PRIVATE KEY")
      begin
        decoded = Base64.decode64(api_key_content)
        api_key_content = decoded if decoded.include?("BEGIN PRIVATE KEY")
      rescue ArgumentError
        # Keep the original value so fastlane can report the key parsing error.
      end
    end

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: api_key_content,
      is_key_content_base64: false,
      duration: 1200,
      in_house: false
    )
  end
end
